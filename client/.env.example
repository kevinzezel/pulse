COMPOSE_PROJECT_NAME=pulse
VERSION=1.10.4

# API bind
API_HOST=127.0.0.1
API_PORT=8000

# API_KEY is auto-generated by start.sh on first run (random 32-byte hex).
# The generated key is printed to the terminal — register it in the frontend
# Settings -> Servers before creating sessions. Leave empty here.
API_KEY=

# HTTPS (self-signed). Toggle via: pulse config tls on
# Empty paths fall back to $HOME/.config/pulse/tls/{cert,key}.pem when uvicorn
# starts under TLS. The CLI fills these in when you run `pulse config tls on`.
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=
