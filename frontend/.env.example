# Dashboard (Next.js) bind
WEB_HOST=127.0.0.1
WEB_PORT=3000

# Shared login password for the dashboard. start.sh aborts if this is still
# "change-me" or empty — set a real password before first run.
AUTH_PASSWORD=change-me

# HS256 secret for the rt:auth JWT cookie. Leave as "change-me" (or empty)
# and start.sh will auto-generate a random 32-byte hex via ensure_auth_secret().
AUTH_JWT_SECRET=change-me

# Set to "true" in production (behind HTTPS / reverse proxy). Must be "false"
# for local dev over plain HTTP — otherwise the browser discards the cookie
# and login silently fails.
AUTH_COOKIE_SECURE=false
